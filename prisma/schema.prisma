datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============ ROLES ============
enum Role {
  ADMIN
  OWNER
  OFFICE
  MECHANIC
}

// ============ AUTH MODELS ============
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  role          Role      @default(MECHANIC)
  workshopId    String?
  workshop      Workshop? @relation(fields: [workshopId], references: [id])
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  workOrders    WorkOrder[] @relation("MechanicWorkOrders")
  diagnosticCases DiagnosticCase[] @relation("DiagnosticCaseCreatedBy")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workshopId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ BUSINESS MODELS ============
model Workshop {
  id           String            @id @default(cuid())
  slug         String            @unique
  name         String
  legalName    String?
  description  String?
  phone        String
  whatsapp     String
  email        String?
  address      String?
  hours        String?
  logoUrl      String?
  heroImageUrl String?
  primaryColor String            @default("#070909")
  accentColor  String            @default("#61D398")
  active       Boolean           @default(true)
  users        User[]
  owners       Owner[]
  vehicles     Vehicle[]
  workOrders   WorkOrder[]
  services     WorkshopService[]
  diagnosticCases DiagnosticCase[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([active])
}

model WorkshopService {
  id          String   @id @default(cuid())
  workshopId  String
  workshop    Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       String?
  category    String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workshopId, active])
  @@index([workshopId, order])
}

model Owner {
  id        String    @id @default(cuid())
  workshopId String?
  workshop  Workshop? @relation(fields: [workshopId], references: [id])
  name      String
  phone     String
  email     String?
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([workshopId])
  @@index([phone])
}

model Vehicle {
  id         String      @id @default(cuid())
  workshopId String?
  workshop   Workshop?   @relation(fields: [workshopId], references: [id])
  plate      String
  brand      String
  model      String
  year       Int?
  km         Int?
  ownerId    String?
  owner      Owner?      @relation(fields: [ownerId], references: [id])
  workOrders WorkOrder[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([workshopId])
  @@index([plate])
  @@unique([workshopId, plate])
}

model WorkOrder {
  id          String   @id @default(cuid())
  workshopId  String?
  workshop    Workshop? @relation(fields: [workshopId], references: [id])
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  description String
  priority    String   // "normal" | "urgente"
  status      String   // "pendiente" | "diagnostico" | "reparando" | "finalizada"
  mechanicId  String?
  mechanic    User?    @relation("MechanicWorkOrders", fields: [mechanicId], references: [id])
  diagnosticCases DiagnosticCase[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workshopId])
  @@index([status])
  @@index([priority])
}

model DiagnosticCase {
  id          String    @id @default(cuid())
  workshopId  String?
  workshop    Workshop? @relation(fields: [workshopId], references: [id])
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?     @relation("DiagnosticCaseCreatedBy", fields: [createdById], references: [id])
  query       String    @db.Text
  symptoms    String?   @db.Text
  dtcCodes    String?
  testsDone   String?   @db.Text
  response    Json
  model       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workshopId])
  @@index([workOrderId])
  @@index([createdById])
  @@index([createdAt])
}
